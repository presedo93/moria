# Bybit API credentials (testnet)
BYBIT_API_KEY=your_testnet_api_key
BYBIT_API_SECRET=your_testnet_api_secret
INTERNAL_SERVICE_TOKEN=

# Bybit endpoints (defaults to testnet)
BYBIT_WS_URL=wss://stream-testnet.bybit.com/v5/public/linear
BYBIT_REST_URL=https://api-testnet.bybit.com

# Trading configuration
TRADING_PAIR=BTCUSDT
KLINE_INTERVAL=1

# Strategy parameters
SMA_SHORT_PERIOD=10
SMA_LONG_PERIOD=30
ORDER_QTY=0.001
SIGNAL_QUEUE_CAPACITY=256
SIGNAL_MAX_INFLIGHT=16

# Risk parameters
MAX_POSITION_SIZE=1.0
MAX_DAILY_LOSS=100.0

# Database
DATABASE_URL=postgres://moria:moria@localhost:5432/moria

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Prometheus metrics endpoint (set empty to disable)
METRICS_ADDR=

# gRPC service addresses
MARKET_DATA_GRPC_ADDR=[::1]:50051
STRATEGY_GRPC_ADDR=[::1]:50052
RISK_GRPC_ADDR=[::1]:50053
ORDER_GRPC_ADDR=[::1]:50054
